{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cd backend && npm run *)",
      "Bash(cd frontend && npm run *)",
      "Bash(npm run *)",
      "Bash(npx nuxi:*)",
      "Bash(npx nest:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git pull)"
    ]
  }
}
